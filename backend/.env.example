APP_ENV=dev
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
APP_VERSION=0.1.0

DATABASE_URL=postgresql+psycopg://vendelo:vendelo@localhost:5434/vendelo
DATABASE_URL_TEST=postgresql+psycopg://vendelo:vendelo@localhost:5434/vendelo_test

# Supabase (production DB pooler + storage). Local dev can keep the Docker URLs above.
# DATABASE_URL=postgresql+psycopg://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://<ref>.supabase.co
# Required for ES256/RS256 JWTs (default on new Supabase projects). HS256 fallback uses SUPABASE_JWT_SECRET.
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>
SUPABASE_STORAGE_BUCKET=assets
SUPABASE_JWT_SECRET=<jwt_secret_from_supabase_dashboard>
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000,https://mxy.mx
# Subdominios del menú público también se permiten vía regex (wild-rooster.localhost, *.mxy.mx)
MENU_PUBLIC_DOMAIN=mxy.mx
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano-2025-08-07
# LLM provider for assistant chat streaming: stub | openai
LLM_PROVIDER=stub
# Product image generation for menu_media skill: stub | openai (uses OPENAI_API_KEY)
IMAGE_PROVIDER=openai
OPENAI_IMAGE_MODEL=gpt-image-2
# Product photo analysis / complement suggestions (menu_intelligence skill)
VISION_PROVIDER=openai
OPENAI_VISION_MODEL=gpt-5.4-nano-2026-03-17
# Assistant conversation cache (optional; falls back to Postgres when Redis is unset)
ASSISTANT_CONVERSATION_CACHE_TTL_SECONDS=300
ASSISTANT_LLM_CONTEXT_MESSAGE_LIMIT=40
ASSISTANT_MAX_TOOL_ITERATIONS=32
MENU_IMPORT_BATCH_MAX_PRODUCTS=15
MENU_IMPORT_FULL_MAX_PRODUCTS=200
MENU_IMPORT_PHOTO_MATCH_THRESHOLD=0.72

# LangSmith tracing (OpenAI Agents SDK + wrap_openai LLM provider)
# https://docs.langchain.com/langsmith/trace-with-openai-agents-sdk
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=venddelo-ai
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Distance Matrix API para cotizar entregas fuera del polígono del courier
GOOGLE_MAPS_API_KEY=

# REDIS_URL=
