APP_ENV=dev
LOG_LEVEL=INFO
API_V1_PREFIX=/api/v1
APP_VERSION=0.1.0

POSTGRES_USER=vendelo
POSTGRES_PASSWORD=vendelo
POSTGRES_DB=vendelo

DATABASE_URL=postgresql+psycopg://vendelo:vendelo@host.docker.internal:5434/vendelo
DATABASE_URL_TEST=postgresql+psycopg://vendelo:vendelo@host.docker.internal:5434/vendelo_test
REDIS_URL=redis://host.docker.internal:6379/0
CORS_ORIGINS=http://localhost:3000,https://venddelo-ai.vercel.app
MENU_PUBLIC_DOMAIN=venddelo.ai

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=assets
SUPABASE_JWT_SECRET=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

RUN_MIGRATIONS=true
PORT=8080
