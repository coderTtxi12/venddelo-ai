# Shared env for `docker compose up` from repo root.
# Copy once: cp .env.example .env
# Also copy app-specific templates if you have not already:
#   cp backend/.env.example backend/.env
#   cp frontend/.env.example frontend/.env.local
#   cp delivery-dashboard/.env.example delivery-dashboard/.env.local

RUN_MIGRATIONS=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DELIVERY_APP_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=assets
NEXT_PUBLIC_MENU_PUBLIC_DOMAIN=localhost
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
